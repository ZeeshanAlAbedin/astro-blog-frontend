---
import MainLayout from "../../layouts/MainLayout.astro";
import { formatDateFull, extractExcerpt} from "../../utils/utils";
import type { SanityDocument } from "@sanity/client";
import { sanityClient } from "sanity:client";
import { PortableText } from "astro-portabletext";

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "post"]{slug}`);
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
  }));
}

const POST_QUERY = `*[_type == "post" && slug.current == $slug][0]{title,dateWritten,notes,body,quip,ref_category[0]->{name}, relatedPosts[]->{title, dateWritten, body, slug}}`;
const post = await sanityClient.fetch<SanityDocument>(POST_QUERY, Astro.params);
console.log(post.relatedPosts);
---
<MainLayout title={post.title} description="Welcome to my blog" page={post.title}>
  <main class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">

        <article class="lg:col-span-8 relative">
          <div class="relative paper-texture rounded-sm spine-shadow border border-surface-container-highest/50 min-h-[1000px] min-w-[200px] lg:min-w-[800px] p-6 lg:p-24 overflow-hidden">
            <div class="ribbon"></div>
            <header class="mb-16">
              <div class="flex justify-between items-baseline mb-8">
                <div class="font-handwriting text-2xl text-primary opacity-70">{post.quip}</div>
                <div class="font-label text-xs lg:mt-0 mt-12 uppercase tracking-[0.2em] text-outline">{formatDateFull(post.dateWritten)}</div>
              </div>
              <h1 class="font-headline text-5xl lg:text-6xl font-bold leading-tight text-on-surface mb-4">{post.title}</h1>
              <div class="w-full h-px bg-surface-container-highest/60"></div>
            </header>
              <!-- Article Body -->
            <div class="max-w-xl mx-auto">
              <PortableText value={post.body} />      
              <!-- Signature -->
              <div class="mt-24 flex justify-end">
                <p class="font-handwriting text-3xl text-on-surface opacity-80">~ Zedric Coil</p>
              </div>
            </div>
          </div>
        </article>

        <aside class="lg:col-span-4 space-y-12 sticky top-32">
          <section class="bg-tertiary-container/30 p-8 rounded-lg border-l border-tertiary/10">
            <div class="flex items-center gap-3 mb-6">
              <span class="material-symbols-outlined text-tertiary text-2xl" style="font-variation-settings: 'FILL' 1;">auto_stories</span>
              <h3 class="font-headline italic text-xl text-on-tertiary-container">Curator's Note</h3>
            </div>
            <p class="font-body text-sm leading-relaxed text-on-tertiary-container/80 mb-6">{post.notes}</p>
                    
          </section>

          <!-- Further Reading -->
          <section class="bg-surface-container rounded-lg p-8">
            <h4 class="font-headline italic text-lg text-primary mb-6">Related Chroniclings</h4>
            
              {post.relatedPosts?.length > 0 && (
                post.relatedPosts.map((rp) => (
                  <div class="space-y-2">
                    <p class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant mb-1">{formatDateFull(rp.dateWritten)}</p>
                    <a class="font-headline text-lg group-hover:text-tertiary transition-colors" href={`/posts/${rp.slug.current}`}>{rp.title}</a>
                    <p class="text-sm text-on-surface-variant mt-1 mb-10 line-clamp-2">{extractExcerpt(rp.body, 100)}</p>
                  </div>
                ))
              )}                   
           
          </section>

          <!-- Metadata -->
          <section class="px-4 py-8 border-t border-outline-variant/20">
            <h4 class="font-label uppercase text-xs tracking-[0.2em] text-on-surface-variant mb-4">Share this Entry</h4>
            <div class="flex gap-4">
              <button class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center hover:bg-primary-container transition-colors">
                <span class="material-symbols-outlined text-lg">share</span>
              </button>
              <button class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center hover:bg-primary-container transition-colors">
                <span class="material-symbols-outlined text-lg">bookmark</span>
              </button>
            </div>
          </section>
        </aside>
        
      </div>
  </main>
</MainLayout>

